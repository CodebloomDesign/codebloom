{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "codebloom",
  "main": "worker.js",
"compatibility_date": "2026-04-07",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "binding": "ASSETS"
  },
  "send_email": [
    {
      "name": "CONTACT_EMAIL",
      "destination_address": "codebloomdesign@gmail.com"
    }
  ],

  "compatibility_flags": [
    "nodejs_compat"
  ]
}
